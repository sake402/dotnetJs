    <DefineConstants Condition="'$(FeatureObjCMarshal)' == 'true'">$(DefineConstants);FEATURE_OBJCMARSHAL</DefineConstants>
  </PropertyGroup>

  <!-- ILLinker settings -->
  <PropertyGroup>
    <ILLinkTrimAssembly>true</ILLinkTrimAssembly>
    <ILLinkDirectory>$(DotnetRuntimeRoot)src/mono/System.Private.CoreLib/src\ILLink\</ILLinkDirectory>
  </PropertyGroup>

